-- Verify EXPLAIN picks the bitmap index scan for k>0
SET enable_seqscan = off;
SET
EXPLAIN (COSTS OFF)
SELECT id FROM p5_docs WHERE body %~~ tre_pattern('hello', 1);
                      QUERY PLAN                       
-------------------------------------------------------
 Bitmap Heap Scan on p5_docs
   Recheck Cond: (body %~~ 'hello@1'::tre_pattern)
   ->  Bitmap Index Scan on p5_idx
         Index Cond: (body %~~ 'hello@1'::tre_pattern)
(4 rows)

