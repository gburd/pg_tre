  ($x$aaac|aabc|abac|abbc|baac|babc|bbac|bbbc$x$, $x$baaababac$x$, 2, true, 'approx'),
  ($x$.*$x$, $x$x01\ff$x$, 2, true, 'approx'),
  ($x$aaaa|bbbb|cccc|ddddd|eeeeee|fffffff|gggg|hhhh|iiiii|jjjjj|kkkkk|llll$x$, $x$XaaaXbbbXccXdddXeeeXfffXgbgXhhhXiiiXjjjXkkkXlllXcbaXaaaa$x$, 2, true, 'approx'),
  ($x$a*a*a*a*a*b$x$, $x$aaaaeaajaab$x$, 2, true, 'approx'),
  ($x$abc$x$, $x$abt$x$, 1, true, 'approx'),
  ($x$abc$x$, $x$xabcgy$x$, 2, true, 'approx'),
  ($x$abc$x$, $x$abbc$x$, 2, true, 'approx'),
  ($x$ab*c$x$, $x$atc$x$, 2, true, 'approx'),
  ($x$ab*bc$x$, $x$awc$x$, 2, true, 'approx'),
  ($x$ab*bc$x$, $x$jbbc$x$, 1, true, 'approx'),
  ($x$ab*bc$x$, $x$mabbbgc$x$, 2, true, 'approx'),
  ($x$ab+bc$x$, $x$aybcu$x$, 2, true, 'approx'),
  ($x$ab+bc$x$, $x$abbc$x$, 2, true, 'approx'),
  ($x$ab?bc$x$, $x$abcz$x$, 2, true, 'approx'),
  ($x$ab?bc$x$, $x$abs$x$, 2, true, 'approx'),
  ($x$ab?c$x$, $x$ab$x$, 2, true, 'approx'),
  ($x$a.c$x$, $x$ab$x$, 1, true, 'approx'),
  ($x$a.c$x$, $x$axd$x$, 1, true, 'approx'),
  ($x$a.*c$x$, $x$xyzc$x$, 1, true, 'approx');
INSERT 0 716
-- ----------------------------------------------------------------------------
-- 1. Functional oracle: every case's tre_amatch verdict must equal expect.
--    Report only aggregate pass/fail counts (deterministic), plus the first
--    few mismatches if any, so a regression is actionable without dumping
--    600+ rows.
-- ----------------------------------------------------------------------------
SELECT kind,
       count(*)                                   AS cases,
       count(*) FILTER (WHERE tre_amatch(input, regex, k) = expect) AS passed,
       count(*) FILTER (WHERE tre_amatch(input, regex, k) <> expect) AS failed
FROM tr_corpus
GROUP BY kind
ORDER BY kind;
  kind  | cases | passed | failed 
--------+-------+--------+--------
 approx |   358 |    358 |      0
 exact  |   358 |    358 |      0
(2 rows)

-- Any individual mismatches (expected to be empty).
SELECT regex, input, k, expect, tre_amatch(input, regex, k) AS got
FROM tr_corpus
WHERE tre_amatch(input, regex, k) <> expect
ORDER BY regex, input, k;
 regex | input | k | expect | got 
-------+-------+---+--------+-----
(0 rows)

-- ----------------------------------------------------------------------------
-- 2. Coverage guarantee: at least half of all cases are approximate
--    (exercise the edit-distance matcher, pg_tre's reason for existing).
-- ----------------------------------------------------------------------------
SELECT (count(*) FILTER (WHERE kind = 'approx') * 100 / count(*)) >= 50
         AS at_least_half_approx,
       count(*) FILTER (WHERE kind = 'approx') AS approx_cases,
       count(*)                                AS total_cases
FROM tr_corpus;
 at_least_half_approx | approx_cases | total_cases 
----------------------+--------------+-------------
 t                    |          358 |         716
(1 row)

-- ----------------------------------------------------------------------------
-- 3. Index path agreement: for a deterministic sample, the indexed
--    operator (text %~~ tre_pattern(regex, k)) must return exactly the
--    same row set as the sequential tre_amatch() scan.
-- ----------------------------------------------------------------------------
CREATE TEMP TABLE tr_docs(id serial PRIMARY KEY, body text);
CREATE TABLE
INSERT INTO tr_docs(body)
  SELECT DISTINCT input FROM tr_corpus WHERE input <> '' ORDER BY 1;
INSERT 0 410
CREATE INDEX tr_docs_idx ON tr_docs USING tre (body);
CREATE INDEX
-- Compare seq vs index for a spread of (regex, k) probes drawn from the
-- corpus.  Returns one 'OK'/'BAD' row per probe.
CREATE OR REPLACE FUNCTION tr_probe(pat text, kk int) RETURNS text
LANGUAGE plpgsql AS $$
DECLARE seq_ids int[]; idx_ids int[];
BEGIN
  SET LOCAL enable_indexscan=off; SET LOCAL enable_bitmapscan=off; SET LOCAL enable_seqscan=on;
  EXECUTE format('SELECT array_agg(id ORDER BY id) FROM tr_docs WHERE tre_amatch(body, %L, %s)', pat, kk)
    INTO seq_ids;
  SET LOCAL enable_seqscan=off; SET LOCAL enable_indexscan=on; SET LOCAL enable_bitmapscan=on;
  EXECUTE format('SELECT array_agg(id ORDER BY id) FROM tr_docs WHERE body %%~~ tre_pattern(%L, %s)', pat, kk)
    INTO idx_ids;
  IF seq_ids IS NOT DISTINCT FROM idx_ids THEN RETURN 'OK   k='||kk||'  '||pat; END IF;
  RETURN format('BAD k=%s %s  seq=%s  idx=%s', kk, pat, seq_ids, idx_ids);
END$$;
CREATE FUNCTION
SELECT tr_probe('a.c', 0);
   tr_probe    
---------------
 OK   k=0  a.c
(1 row)

SELECT tr_probe('a.c', 1);
   tr_probe    
---------------
 OK   k=1  a.c
(1 row)

SELECT tr_probe('(ab|cd)', 0);
     tr_probe      
-------------------
 OK   k=0  (ab|cd)
(1 row)

SELECT tr_probe('(ab|cd)', 1);
     tr_probe      
-------------------
 OK   k=1  (ab|cd)
(1 row)

SELECT tr_probe('a[b-d]e', 0);
     tr_probe      
-------------------
 OK   k=0  a[b-d]e
(1 row)

SELECT tr_probe('a[b-d]e', 2);
     tr_probe      
-------------------
 OK   k=2  a[b-d]e
(1 row)

SELECT tr_probe('xyz', 0);
   tr_probe    
---------------
 OK   k=0  xyz
(1 row)

SELECT tr_probe('xyz', 1);
   tr_probe    
---------------
 OK   k=1  xyz
(1 row)

RESET client_min_messages;
RESET
DROP FUNCTION tr_probe(text, int);
DROP FUNCTION
DROP INDEX tr_docs_idx;
DROP INDEX
