+/*
+ * pg_tre: progress hook for wall-clock match-timeout enforcement.
+ *
+ * The real implementation lives in src/util/tre_match.c (which is
+ * postgres.h-free); it returns nonzero when the PG-installed deadline
+ * callback wants the match aborted.  Declared here as a plain extern so
+ * no pg_tre/PG headers are pulled into the vendored matcher, and called
+ * periodically from the per-position NFA loop below.
+ *
+ * A __weak__ default is provided so the vendored TRE library and its
+ * stand-alone tools (e.g. agrep) link cleanly on their own; when linked
+ * into pg_tre.so the strong definition in tre_match.c overrides it.  If
+ * the compiler lacks weak-symbol support we fall back to a plain
+ * declaration (pg_tre always supplies the strong definition; only the
+ * never-built-here agrep tool would then fail to link standalone).
+ */
+#if defined(__GNUC__) || defined(__clang__)
+int tre_progress_check(void) __attribute__((weak));
+int tre_progress_check(void) { return 0; }
+#else
+extern int tre_progress_check(void);
+#endif
+
 #define TRE_M_COST	0
 #define TRE_M_NUM_INS	1
 #define TRE_M_NUM_DEL	2
